# 未来容器化可选配置（示例文件，不会被默认加载）
# 使用方式：复制为 application-container.yml 并激活 container profile。
spring:
  datasource:
    url: jdbc:mysql://mysql:3306/flash_sale?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: 123456

  data:
    redis:
      host: redis
      port: 6379
      database: 0

  rabbitmq:
    host: rabbitmq
    port: 5672
    username: admin
    password: 123456
    virtual-host: /

app:
  redis:
    env-prefix: container
